<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BlogApp Admin</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600&family=Playfair+Display:wght@600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/BlogApp.styles.css" asp-append-version="true" />
</head>
<body>
    @{
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
        var currentUrl = Context.Request.Path + Context.Request.QueryString;
    }
    <div class="d-flex" style="min-height: 100vh;">
        <nav class="admin-sidebar">
            <div class="admin-sidebar-brand">BlogApp</div>

            <a asp-controller="Home" asp-action="Index" class="admin-sidebar-link admin-sidebar-back">
                &larr; Home
            </a>

            <div class="admin-sidebar-nav">
                <a asp-controller="Dashboard" asp-action="Index" class="admin-sidebar-link @(currentController == "Dashboard" ? "active" : "")">
                    <i class="bi bi-speedometer2"></i> Dashboard
                </a>
                <a asp-controller="Post" asp-action="Index" class="admin-sidebar-link @(currentController == "Post" ? "active" : "")">
                    <i class="bi bi-file-text"></i> Posts
                </a>
                <a asp-controller="Category" asp-action="Index" class="admin-sidebar-link @(currentController == "Category" ? "active" : "")">
                    <i class="bi bi-tags"></i> Categories
                </a>
                <a asp-controller="Comment" asp-action="Index" class="admin-sidebar-link @(currentController == "Comment" ? "active" : "")">
                    <i class="bi bi-chat-dots"></i> Comments
                </a>
                <a asp-controller="User" asp-action="Index" class="admin-sidebar-link @(currentController == "User" ? "active" : "")">
                    <i class="bi bi-people"></i> Users
                </a>
            </div>
        </nav>

        <div class="flex-grow-1">
            <div class="admin-topbar">
                <span class="admin-topbar-title">@ViewData["Title"]</span>
                <div class="d-flex align-items-center gap-3">
                    <div class="d-flex align-items-center gap-1">
                        <a asp-controller="Language" asp-action="SetLanguage"
                           asp-route-culture="tr" asp-route-returnUrl="@currentUrl"
                           class="@(System.Globalization.CultureInfo.CurrentCulture.Name == "tr" ? "fw-bold text-decoration-none" : "text-decoration-none text-muted")">
                            TR
                        </a>
                        <span class="text-muted">/</span>
                        <a asp-controller="Language" asp-action="SetLanguage"
                           asp-route-culture="en" asp-route-returnUrl="@currentUrl"
                           class="@(System.Globalization.CultureInfo.CurrentCulture.Name == "en" ? "fw-bold text-decoration-none" : "text-decoration-none text-muted")">
                            EN
                        </a>
                    </div>
                    <span class="admin-topbar-name">@User.Identity.Name</span>
                    <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                        <button type="submit" class="btn btn-outline-secondary btn-sm">Log out</button>
                    </form>
                </div>
            </div>

            <div class="admin-content">
                <div class="container-fluid p-4">
                    @RenderBody()
                </div>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>