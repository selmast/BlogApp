@using BlogApp.Extensions
@model List<BlogApp.Models.Post>
@{
    ViewData["Title"] = ViewBag.CategoryName;
}

<div class="row">
    <div class="col-lg-8 mx-auto">

        <p class="text-muted mb-1" style="text-transform: uppercase; font-size: 12px; letter-spacing: 1px;">@Localizer["Category"]</p>
        <h2>@ViewBag.CategoryName</h2>

        @if (Model != null && Model.Any())
        {
            <div class="post-list">
                @foreach (var post in Model)
                {
                    <div class="post-row">
                        @if (!string.IsNullOrEmpty(post.CoverImageUrl))
                        {
                            <a asp-action="Details" asp-route-id="@post.Id">
                                <img src="@post.CoverImageUrl" alt="@post.LocalizedTitle()" />
                            </a>
                        }
                        <div class="post-row-content">
                            <h5>
                                <a asp-action="Details" asp-route-id="@post.Id">@post.LocalizedTitle()</a>
                            </h5>
                            <p class="text-muted">
                                <small>@post.PublishDate.ToShortDateString()</small>
                            </p>
                            <p>@post.LocalizedSummary()</p>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <p>@Localizer["NoPostsInCategoryYet"]</p>
        }

        <a asp-controller="Home" asp-action="Index" class="d-inline-block mt-4 pt-3 border-top">@Localizer["BackToHome"]</a>
    </div>
</div>