@model List<BlogApp.Models.Post>
@{
    ViewData["Title"] = "All Posts";
}

<h2>All Posts</h2>

@if (Model != null && Model.Any())
{
    foreach (var post in Model)
    {
        <div class="card mb-3">
            @if (!string.IsNullOrEmpty(post.CoverImageUrl))
            {
                <a asp-action="Details" asp-route-id="@post.Id">
                    <img src="@post.CoverImageUrl" class="card-img-top" alt="@post.Title" style="max-height:250px; object-fit:cover;" />
                </a>
            }
            <div class="card-body">
                <h5 class="card-title">
                    <a asp-action="Details" asp-route-id="@post.Id">@post.Title</a>
                </h5>
                <p class="card-text text-muted">
                    <small>@post.Category?.Name | @post.PublishDate.ToShortDateString()</small>
                </p>
                <p class="card-text">@post.Summary</p>
            </div>
        </div>
    }
}
else
{
    <p>No posts yet.</p>
}