@using BlogApp.Extensions
@model List<BlogApp.Models.Post>
@{
    ViewData["Title"] = "Search Results";
}

<div class="row">
    <div class="col-lg-8 mx-auto">

        <h2>@Localizer["SearchResultsFor"] "@ViewBag.SearchTerm"</h2>

        @if (Model != null && Model.Any())
        {
            <div class="post-list">
                @foreach (var post in Model)
                {
                    <div class="post-row">
                        @if (!string.IsNullOrEmpty(post.CoverImageUrl))
                        {
                            <a asp-action="Details" asp-route-id="@post.Id">
                                <img src="@post.CoverImageUrl" alt="@post.LocalizedTitle()" />
                            </a>
                        }
                        <div class="post-row-content">
                            <h5>
                                <a asp-action="Details" asp-route-id="@post.Id">@post.LocalizedTitle()</a>
                            </h5>
                            <p class="text-muted">
                                <small>@post.Category?.LocalizedName() | @post.PublishDate.ToShortDateString()</small>
                            </p>
                            <p>@post.LocalizedSummary()</p>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <p>@Localizer["NoPostsFoundMatching"] "@ViewBag.SearchTerm".</p>
        }

        <a asp-controller="Home" asp-action="Index">@Localizer["BackToHome"]</a>
    </div>
</div>