@model BlogApp.Models.Post
@{
    ViewData["Title"] = "Edit Post";
    Layout = "_AdminLayout";
}

<div class="row">
    <div class="col-lg-8">
        <form asp-action="Edit" enctype="multipart/form-data">
            <input type="hidden" asp-for="Id" />

            <div class="form-group mb-3">
                <label asp-for="Title"></label>
                <input asp-for="Title" class="form-control" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Summary"></label>
                <input asp-for="Summary" class="form-control" />
            </div>

            <div class="form-group mb-3">
                <label asp-for="Content"></label>
                <textarea asp-for="Content" class="form-control" rows="8"></textarea>
                <span asp-validation-for="Content" class="text-danger"></span>
            </div>

            @if (!string.IsNullOrEmpty(Model.CoverImageUrl))
            {
                <img src="@Model.CoverImageUrl" style="max-width:200px;" class="mb-2 d-block rounded" />
            }
            <div class="form-group mb-3">
                <label>Cover Image (leave empty to keep current)</label>
                <input type="file" name="CoverImage" class="form-control" accept="image/*" />
            </div>

            <div class="form-group mb-3">
                <label asp-for="CategoryId"></label>
                <select asp-for="CategoryId" asp-items="ViewBag.CategoryList" class="form-control"></select>
            </div>

            <div class="form-check mb-3">
                <input asp-for="IsActive" class="form-check-input" />
                <label asp-for="IsActive" class="form-check-label"></label>
            </div>

            <button type="submit" class="btn btn-primary">Save</button>
        </form>

        <a asp-action="Index" class="d-block mt-3">Back to List</a>
    </div>
</div>