@{
    ViewData["Title"] = Localizer["AdminLogin"].Value;
    ViewData["HideCategoryNav"] = true;
}

<div class="login-wrapper">
    <div class="row w-100">
        <div class="col-md-5 mx-auto">

            <div class="section-heading-row">
                <h1 class="mb-0">@Localizer["AdminLogin"]</h1>
            </div>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger">@ViewBag.Error</div>
            }

            <form asp-controller="Account" asp-action="Login" method="post">
                <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />

                <div class="form-group mb-3">
                    <label>@Localizer["Username"]</label>
                    <input name="username" class="form-control" required />
                </div>

                <div class="form-group mb-3">
                    <label>@Localizer["Password"]</label>
                    <input name="password" type="password" class="form-control" required />
                </div>

                <button type="submit" class="btn btn-primary w-100">@Localizer["LogIn"]</button>
            </form>
        </div>
    </div>
</div>