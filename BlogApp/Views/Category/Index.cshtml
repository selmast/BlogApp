@model IEnumerable<BlogApp.Models.Category>

@{
    ViewData["Title"] = Localizer["Categories"].Value;
    Layout = "_AdminLayout";
}

<div class="mb-3">
    <div class="mb-3">
        <a asp-action="Create" class="btn btn-primary btn-sm">+ @Localizer["CreateNewCategory"]</a>
    </div>
</div>

<div class="admin-table-wrapper">
    <table class="table table-stack mb-0">
        <thead>
            <tr>
                <th>@Localizer["Name"]</th>
                <th>@Localizer["Actions"]</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td data-label="@Localizer["Name"]">@item.Name</td>
                    <td data-label="@Localizer["Actions"]">
                        <a asp-action="Edit" asp-route-id="@item.Id">@Localizer["Edit"]</a> |
                        <a asp-action="Delete" asp-route-id="@item.Id">@Localizer["Delete"]</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>