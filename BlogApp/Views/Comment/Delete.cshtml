@model BlogApp.Models.Comment
@{
    ViewData["Title"] = Localizer["DeleteCommentPageTitle"].Value;
    Layout = "_AdminLayout";
}

<p>@Localizer["ConfirmDeleteComment", Model.Author, Model.Post?.Title]</p>
<blockquote>@Model.Content</blockquote>

<form asp-action="Delete">
    <input type="hidden" asp-for="Id" />
    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-danger">@Localizer["Delete"]</button>
        <a asp-action="Index" class="btn btn-outline-secondary">@Localizer["Cancel"]</a>
    </div>
</form>