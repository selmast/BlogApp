@model BlogApp.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = Localizer["Dashboard"].Value;
    Layout = "_AdminLayout";
}

<div class="row mb-3 g-3">
    <div class="col-md-6">
        <div class="dashboard-banner">
            <h2>@Localizer["HelloUser", User.Identity.Name]</h2>
            <p>@Localizer["DashboardIntro"]</p>
            <a asp-controller="Post" asp-action="Create" class="btn">+ @Localizer["NewPost"]</a>
        </div>
    </div>
    <div class="col-md-6">
        <a asp-controller="Post" asp-action="Index" class="text-decoration-none">
            <div class="stat-mini-card">
                <div class="stat-mini-icon"><i class="bi bi-file-text"></i></div>
                <div>
                    <div class="stat-label">@Localizer["TotalPosts"]</div>
                    <div class="stat-value">@Model.TotalPosts</div>
                </div>
            </div>
        </a>
        <a asp-controller="Category" asp-action="Index" class="text-decoration-none">
            <div class="stat-mini-card">
                <div class="stat-mini-icon"><i class="bi bi-tags"></i></div>
                <div>
                    <div class="stat-label">@Localizer["TotalCategories"]</div>
                    <div class="stat-value">@Model.TotalCategories</div>
                </div>
            </div>
        </a>
        <a asp-controller="Comment" asp-action="Index" class="text-decoration-none">
            <div class="stat-mini-card">
                <div class="stat-mini-icon"><i class="bi bi-chat-dots"></i></div>
                <div>
                    <div class="stat-label">@Localizer["TotalComments"]</div>
                    <div class="stat-value">@Model.TotalComments</div>
                </div>
            </div>
        </a>
    </div>
</div>

<div class="mb-4 d-flex flex-wrap gap-2">
    <a asp-controller="Category" asp-action="Create" class="btn btn-outline-secondary btn-sm">+ @Localizer["NewCategory"]</a>
    <a asp-controller="User" asp-action="Create" class="btn btn-outline-secondary btn-sm">+ @Localizer["NewUser"]</a>
    <a asp-controller="Comment" asp-action="Index" class="btn btn-outline-secondary btn-sm">@Localizer["ModerateComments"]</a>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="section-heading-row">
            <h3 class="mb-0">@Localizer["RecentlyAddedPosts"]</h3>
        </div>

        @if (Model.RecentPosts != null && Model.RecentPosts.Any())
        {
            <div>
                @foreach (var post in Model.RecentPosts)
                {
                    <div class="most-read-row">
                        @if (!string.IsNullOrEmpty(post.CoverImageUrl))
                        {
                            <a asp-controller="Post" asp-action="Edit" asp-route-id="@post.Id">
                                <img src="@post.CoverImageUrl" alt="@post.Title" />
                            </a>
                        }
                        <div class="flex-grow-1">
                            <a asp-controller="Post" asp-action="Edit" asp-route-id="@post.Id" class="d-block">@post.Title</a>
                            <small class="text-muted">@post.Category?.Name | @post.PublishDate.ToShortDateString() | @(post.IsActive ? Localizer["Active"] : Localizer["Inactive"])</small>
                        </div>
                    </div>
                }
            </div>

            <a asp-controller="Post" asp-action="Index" class="btn btn-outline-secondary btn-sm mt-2">@Localizer["ViewAllPosts"]</a>
        }
        else
        {
            <p>@Localizer["NoPostsYet"]</p>
        }
    </div>

    <div class="col-md-6">
        <div class="section-heading-row">
            <h3 class="mb-0">@Localizer["TopPerformingPosts"]</h3>
        </div>

        @if (Model.TopPosts != null && Model.TopPosts.Any())
        {
            <div>
                @foreach (var post in Model.TopPosts)
                {
                    <div class="most-read-row">
                        @if (!string.IsNullOrEmpty(post.CoverImageUrl))
                        {
                            <a asp-controller="Post" asp-action="Edit" asp-route-id="@post.Id">
                                <img src="@post.CoverImageUrl" alt="@post.Title" />
                            </a>
                        }
                        <div class="flex-grow-1">
                            <a asp-controller="Post" asp-action="Edit" asp-route-id="@post.Id" class="d-block">@post.Title</a>
                            <small class="text-muted">@post.Category?.Name | @post.ViewCount views</small>
                        </div>
                    </div>
                }
            </div>

            <a asp-controller="Post" asp-action="Popular" class="btn btn-outline-secondary btn-sm mt-2">@Localizer["ViewAllPopularPosts"]</a>
        }
        else
        {
            <p>@Localizer["NoPostsYet"]</p>
        }
    </div>
</div>