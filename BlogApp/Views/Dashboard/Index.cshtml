@model BlogApp.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    Layout = "_AdminLayout"; 
}



<div class="mb-4 d-flex flex-wrap gap-2">
    <a asp-controller="Post" asp-action="Create" class="btn btn-primary">+ New Post</a>
    <a asp-controller="Category" asp-action="Create" class="btn btn-secondary">+ New Category</a>
    <a asp-controller="User" asp-action="Create" class="btn btn-secondary">+ New User</a>
    <a asp-controller="Comment" asp-action="Index" class="btn btn-outline-secondary">Moderate Comments</a>
</div>

<div class="row mb-4 g-3">
    <div class="col-md-4">
        <a asp-controller="Post" asp-action="Index" class="text-decoration-none text-dark">
            <div class="card text-center">
                <div class="card-body">
                    <h5 class="card-title">Total Posts</h5>
                    <p class="display-4">@Model.TotalPosts</p>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-4">
        <a asp-controller="Category" asp-action="Index" class="text-decoration-none text-dark">
            <div class="card text-center">
                <div class="card-body">
                    <h5 class="card-title">Total Categories</h5>
                    <p class="display-4">@Model.TotalCategories</p>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-4">
        <a asp-controller="Comment" asp-action="Index" class="text-decoration-none text-dark">
            <div class="card text-center">
                <div class="card-body">
                    <h5 class="card-title">Total Comments</h5>
                    <p class="display-4">@Model.TotalComments</p>
                </div>
            </div>
        </a>
    </div>
</div>

<h3>Recently Added Posts</h3>

@if (Model.RecentPosts != null && Model.RecentPosts.Any())
{
    <div class="card mb-3" style="overflow: hidden;">
        <table class="table table-stack mb-0">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Category</th>
                    <th>Publish Date</th>
                    <th>Active</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var post in Model.RecentPosts)
                {
                    <tr>
                        <td data-label="Title"><a asp-controller="Post" asp-action="Edit" asp-route-id="@post.Id">@post.Title</a></td>
                        <td data-label="Category">@post.Category?.Name</td>
                        <td data-label="Publish Date">@post.PublishDate.ToShortDateString()</td>
                        <td data-label="Active">@(post.IsActive ? "Yes" : "No")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <a asp-controller="Post" asp-action="Index" class="btn btn-outline-secondary btn-sm">View All Posts</a>
}
else
{
    <p>No posts yet.</p>
}