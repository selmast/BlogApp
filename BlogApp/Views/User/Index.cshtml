@model IEnumerable<BlogApp.Models.User>
@{
    ViewData["Title"] = Localizer["Users"].Value;
    Layout = "_AdminLayout";
}

@if (TempData["DeleteError"] != null)
{
    <div class="alert alert-danger">@TempData["DeleteError"]</div>
}

<div class="mb-3">
    <a asp-action="Create" class="btn btn-primary btn-sm">+ @Localizer["CreateNewUser"]</a>
</div>

<div class="admin-table-wrapper">
    <table class="table table-stack mb-0">
        <thead>
            <tr>
                <th>@Localizer["Username"]</th>
                <th>@Localizer["FullName"]</th>
                <th>@Localizer["Actions"]</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td data-label="@Localizer["Username"]">@item.Username</td>
                    <td data-label="@Localizer["FullName"]">@item.FullName</td>
                    <td data-label="@Localizer["Actions"]">
                        <a asp-action="Edit" asp-route-id="@item.Id">@Localizer["Edit"]</a> |
                        <a asp-action="Delete" asp-route-id="@item.Id">@Localizer["Delete"]</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>