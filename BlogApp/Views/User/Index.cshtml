@model IEnumerable<BlogApp.Models.User>
@{
    ViewData["Title"] = "Users";
    Layout = "_AdminLayout";
}

@if (TempData["DeleteError"] != null)
{
    <div class="alert alert-danger">@TempData["DeleteError"]</div>
}

<div class="mb-3">
    <a asp-action="Create" class="btn btn-primary btn-sm">+ Create New User</a>
</div>

<div class="admin-table-wrapper">
    <table class="table table-stack mb-0">
        <thead>
            <tr>
                <th>Username</th>
                <th>Full Name</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td data-label="Username">@item.Username</td>
                    <td data-label="Full Name">@item.FullName</td>
                    <td data-label="Actions">
                        <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                        <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>