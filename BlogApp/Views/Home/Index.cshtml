@model BlogApp.ViewModels.HomeViewModel
@{
    ViewData["Title"] = "Home";
}

<div class="row">
    <div class="col-md-8">
        <h2>Recent Posts</h2>

        @if (Model.RecentPosts != null && Model.RecentPosts.Any())
        {
            foreach (var post in Model.RecentPosts)
            {
                <div class="card mb-3">
                    @if (!string.IsNullOrEmpty(post.CoverImageUrl))
                    {
                        <img src="@post.CoverImageUrl" class="card-img-top" alt="@post.Title" style="max-height:250px; object-fit:cover;" />
                    }
                    <div class="card-body">
                        <h5 class="card-title">
                            <a asp-controller="Post" asp-action="Details" asp-route-id="@post.Id">@post.Title</a>
                        </h5>
                        <p class="card-text text-muted">
                            <small>@post.Category?.Name | @post.PublishDate.ToShortDateString()</small>
                        </p>
                        <p class="card-text">@post.Summary</p>
                    </div>
                </div>
            }
        }
        else
        {
            <p>No posts yet.</p>
        }

        <h2 class="mt-4">Most Read</h2>

        @if (Model.MostReadPosts != null && Model.MostReadPosts.Any())
        {
            <ul class="list-group mb-4">
                @foreach (var post in Model.MostReadPosts)
                {
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <a asp-controller="Post" asp-action="Details" asp-route-id="@post.Id">@post.Title</a>
                        <span class="badge bg-secondary">@post.ViewCount views</span>
                    </li>
                }
            </ul>
        }
    </div>

    <div class="col-md-4">
        <h2>Categories</h2>

        @if (Model.Categories != null && Model.Categories.Any())
        {
            <ul class="list-group">
                @foreach (var category in Model.Categories)
                {
                    <li class="list-group-item">@category.Name</li>
                }
            </ul>
        }
    </div>
</div>