@model BlogApp.ViewModels.HomeViewModel
@{
    ViewData["Title"] = "Home";
}

<div class="section-heading-row">
    <h2 class="mb-0">Recent Posts</h2>
    <a asp-controller="Post" asp-action="All">See All Posts &rarr;</a>
</div>

@if (Model.RecentPosts != null && Model.RecentPosts.Any())
{
    <div class="recent-grid mb-5">
        @foreach (var post in Model.RecentPosts)
        {
            <div class="recent-grid-item">
                @if (!string.IsNullOrEmpty(post.CoverImageUrl))
                {
                    <a asp-controller="Post" asp-action="Details" asp-route-id="@post.Id">
                        <img src="@post.CoverImageUrl" alt="@post.Title" />
                    </a>
                }
                <h5>
                    <a asp-controller="Post" asp-action="Details" asp-route-id="@post.Id">@post.Title</a>
                </h5>
                <p class="text-muted">
                    <small>@post.Category?.Name | @post.PublishDate.ToShortDateString()</small>
                </p>
                <p>@post.Summary</p>
            </div>
        }
    </div>
}
else
{
    <p>No posts yet.</p>
}

<div class="section-heading-row">
    <h2 class="mb-0">Most Read</h2>
    <a asp-controller="Post" asp-action="Popular">See All Popular Posts &rarr;</a>
</div>

@if (Model.MostReadPosts != null && Model.MostReadPosts.Any())
{
    <div>
        @foreach (var post in Model.MostReadPosts)
        {
            <div class="most-read-row">
                @if (!string.IsNullOrEmpty(post.CoverImageUrl))
                {
                    <a asp-controller="Post" asp-action="Details" asp-route-id="@post.Id">
                        <img src="@post.CoverImageUrl" alt="@post.Title" />
                    </a>
                }
                <div class="flex-grow-1">
                    <a asp-controller="Post" asp-action="Details" asp-route-id="@post.Id" class="d-block">@post.Title</a>
                    <small class="text-muted">@post.Category?.Name</small>
                </div>
            </div>
        }
    </div>
}