@using BlogApp.Extensions
@model BlogApp.ViewModels.HomeViewModel
@{
    ViewData["Title"] = "Home";
}

<div class="section-heading-row">
    <h2 class="mb-0">@Localizer["RecentPosts"]</h2>
    <a asp-controller="Post" asp-action="All">@Localizer["SeeAllPosts"]</a>
</div>

@if (Model.RecentPosts != null && Model.RecentPosts.Any())
{
    <div class="recent-grid mb-5">
        @foreach (var post in Model.RecentPosts)
        {
            <div class="recent-grid-item">
                @if (!string.IsNullOrEmpty(post.CoverImageUrl))
                {
                    <a asp-controller="Post" asp-action="Details" asp-route-id="@post.Id">
                        <img src="@post.CoverImageUrl" alt="@post.LocalizedTitle()" />
                    </a>
                }
                <h5>
                    <a asp-controller="Post" asp-action="Details" asp-route-id="@post.Id">@post.LocalizedTitle()</a>
                </h5>
                <p class="text-muted">
                    <small>@post.Category?.LocalizedName() | @post.PublishDate.ToShortDateString()</small>
                </p>
                <p>@post.LocalizedSummary()</p>
            </div>
        }
    </div>
}
else
{
    <p>@Localizer["NoPostsYet"]</p>
}

<div class="row">
    <div class="col-md-6">
        <div class="section-heading-row">
            <h2 class="mb-0">@Localizer["MostRead"]</h2>
        </div>

        @if (Model.MostReadPosts != null && Model.MostReadPosts.Any())
        {
            <div>
                @foreach (var post in Model.MostReadPosts)
                {
                    <div class="most-read-row">
                        @if (!string.IsNullOrEmpty(post.CoverImageUrl))
                        {
                            <a asp-controller="Post" asp-action="Details" asp-route-id="@post.Id">
                                <img src="@post.CoverImageUrl" alt="@post.LocalizedTitle()" />
                            </a>
                        }
                        <div class="flex-grow-1">
                            <a asp-controller="Post" asp-action="Details" asp-route-id="@post.Id" class="d-block">@post.LocalizedTitle()</a>
                            <small class="text-muted">@post.Category?.LocalizedName()</small>
                        </div>
                    </div>
                }
            </div>

            <a asp-controller="Post" asp-action="Popular" class="btn btn-outline-secondary btn-sm mt-2">@Localizer["SeeAll"]</a>
        }
    </div>

    <div class="col-md-6">
        <div class="section-heading-row">
            <h2 class="mb-0">@Localizer["RecentlyDiscussed"]</h2>
        </div>

        @if (Model.RecentlyDiscussedPosts != null && Model.RecentlyDiscussedPosts.Any())
        {
            <div>
                @foreach (var post in Model.RecentlyDiscussedPosts)
                {
                    <div class="most-read-row">
                        @if (!string.IsNullOrEmpty(post.CoverImageUrl))
                        {
                            <a asp-controller="Post" asp-action="Details" asp-route-id="@post.Id">
                                <img src="@post.CoverImageUrl" alt="@post.LocalizedTitle()" />
                            </a>
                        }
                        <div class="flex-grow-1">
                            <a asp-controller="Post" asp-action="Details" asp-route-id="@post.Id" class="d-block">@post.LocalizedTitle()</a>
                            <small class="text-muted">@post.Category?.LocalizedName()</small>
                        </div>
                    </div>
                }
            </div>

            <a asp-controller="Post" asp-action="Discussed" class="btn btn-outline-secondary btn-sm mt-2">@Localizer["SeeAll"]</a>
        }
    </div>
</div>